DATABASE_URL=postgresql+pg8000://<user>:<password>@<host>:5432/<database>
SECRET_KEY=<change-this-to-a-random-string-of-at-least-32-characters>
ENVIRONMENT=development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_NAME=LSS ERP
DEBUG=false
API_DOCS_ENABLED=true
AUTO_CREATE_SCHEMA=true
ALLOWED_ORIGINS=https://erp.sauter.co.kr,http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=erp.sauter.co.kr,localhost,127.0.0.1

# 공공데이터포털 인증키
NTS_BUSINESS_STATUS_SERVICE_KEY=
POSTAL_SERVICE_KEY=

# Notification mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=LSS ERP
SMTP_ADMIN_EMAILS=
